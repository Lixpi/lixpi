{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Lixpi",
    "version": "0.0.1",
    "identifier": "com.lixpi.app",
    "build": {
        "beforeDevCommand": "pnpm --filter lixpi-web-ui dev",
        "beforeBuildCommand": "pnpm --filter lixpi-web-ui build",
        "devUrl": "http://localhost:5173",
        "frontendDist": "../../../services/web-ui/dist"
    },
    "app": {
        "windows": [
            {
                "title": "Lixpi",
                "width": 1440,
                "height": 900,
                "minWidth": 1024,
                "minHeight": 700,
                "resizable": true,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": "default-src 'self' tauri://localhost http://tauri.localhost; connect-src 'self' ipc: http://ipc.localhost wss://*.lixpi.com wss://localhost:* https://*.auth0.com https://api.stripe.com https://*.stripe.com https://*.stripe.network; script-src 'self' 'unsafe-inline' https://js.stripe.com; frame-src https://*.stripe.com; img-src 'self' asset: data: blob: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:;"
        }
    },
    "plugins": {
        "deep-link": {
            "desktop": {
                "schemes": ["lixpi"]
            },
            "mobile": [
                {
                    "host": "app.lixpi.com",
                    "pathPrefix": ["/auth/callback"]
                }
            ]
        }
    },
    "bundle": {
        "active": true,
        "targets": ["app", "dmg"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "macOS": {
            "minimumSystemVersion": "11.0"
        }
    }
}
